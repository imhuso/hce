# 拷贝为 .env（已在 .gitignore 中，不会进 git）后填入实际值
# docker compose 会自动读取同目录 .env 文件

# Embedding 供应商：openai | ollama | voyageai | gemini
HCE_EMBEDDING_PROVIDER=gemini
HCE_EMBEDDING_MODEL=gemini-embedding-001

# 必填：选定供应商的 API Key（不要直接写进 configs/config.yaml）
HCE_EMBEDDING_API_KEY=

# 可选：自托管或代理时使用（LM Studio 用 http://host.docker.internal:1234/v1）
HCE_EMBEDDING_BASE_URL=

# 可选：手动指定维度。当用 LM Studio / vLLM 跑非 OpenAI 模型时必填
# Qwen3-Embedding-8B = 4096；nomic-embed-text = 768；text-embedding-3-small = 1536
HCE_EMBEDDING_DIM=
